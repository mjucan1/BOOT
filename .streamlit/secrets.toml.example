# Streamlit secrets. TWO places this is used:
#   1) Local dashboard test: copy this file to `.streamlit/secrets.toml`.
#   2) Streamlit Community Cloud: paste these keys into the app's
#      Settings -> Secrets box (do NOT commit the real file).
#
# DATABASE_URL points the dashboard at the SAME Postgres your PC scraper writes.
DATABASE_URL = "postgresql+psycopg2://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Shared password for the "small team" gate. Anyone with the link needs this.
APP_PASSWORD = "choose-a-strong-shared-password"
