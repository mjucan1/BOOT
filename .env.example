# Copy to `.env` and fill in. Loaded by scrape_weekly.ps1 for the weekly run.
# This is the SAME Postgres URL the dashboard uses (Supabase/Neon).
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Scrape tuning (optional). Higher delay + jitter = gentler on the bot wall.
BBXRAY_DELAY=1.0
BBXRAY_JITTER=0.5
BBXRAY_MAX_PRODUCTS=1500
BBXRAY_CONTACT=m26jucan@gmail.com

# Only needed if one IP starts getting blocked (e.g. scraping the FULL catalog
# weekly). Point at a rotating RESIDENTIAL proxy gateway; each request then
# exits from a different home IP. Leave blank to scrape directly.
# BBXRAY_PROXY=http://user:pass@gate.provider.com:7777

# Foot-traffic auto-sync (Dewey). Needed only if you schedule foot_traffic_sync.ps1.
# From the dataset's Bulk API page: the API key and the endpoint URL.
DEWEY_API_KEY=your-dewey-api-key
DEWEY_PRODUCT_PATH=https://app.deweydata.io/external-api/v3/products/<id>/files
